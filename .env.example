# z.ai API Configuration
ZAI_API_KEY=your_zai_api_key_here
ZAI_API_URL=https://api.z.ai/v1

# Yandex SpeechKit Configuration
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here
YANDEX_TTS_URL=https://stt.api.cloud.yandex.net/speech/v1/tts:synthesize

# TTS Settings
YANDEX_VOICE=alice
YANDEX_LANGUAGE=ru-RU
TTS_MAX_CHARS_PER_DAY=2000
TTS_SPEECH_RATE_CHARS_PER_SEC=8.0

# Video Settings
VIDEO_MAX_DURATION_SECONDS=60
VIDEO_TARGET_DURATION_SECONDS=50
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920

# Puppeteer Service
PUPPETEER_SERVICE_URL=http://puppeteer:3000

# Paths
RAW_DIR=/app/raw
OUTPUT_DIR=/app/output
STATE_DIR=/app/state
LOG_LEVEL=INFO
